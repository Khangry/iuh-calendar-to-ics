# Copy sang .env (local) hoặc set trong Vercel Project Settings > Environment Variables.

# client_secret của app OneUni (OAuth2). Bắt buộc.
CLIENT_SECRET=LcC4X5PeQ<MiQ;L

# Base API dữ liệu của trường (= url_uni). Đổi để mở rộng sang trường khác.
URL_UNI=https://sv.iuh.edu.vn/AppSVGV/
USER_TYPE=2
SCHOOL_CODE=IUH

# Khoá mã hoá credential nhúng vào URL subscribe. Bắt buộc, đặt chuỗi bí mật dài.
ENCRYPTION_KEY=

# Khoảng ngày mặc định của feed (ngày về trước / về sau kể từ hôm nay).
DEFAULT_DAYS_BACK=90
DEFAULT_DAYS_FORWARD=180

# Ít khi cần đổi:
# AUTH_BASE=https://mobile.oneuni.com.vn
# CLIENT_ID=mobile_flutter
# SCOPE=offline_access openid
